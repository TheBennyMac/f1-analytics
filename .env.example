# F1 Analytics — environment variable template
# Copy to .env and fill in values. Never commit .env.

# FastF1 cache path (default used in code; override if needed)
# FASTF1_CACHE_DIR=data/cache/

# OpenF1 API (no auth required for public endpoints — placeholder for future)
# OPENF1_BASE_URL=https://api.openf1.org/v1
